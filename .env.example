# Database images
STUDENT_DB_IMAGE=mysql:8.4
COURSE_DB_IMAGE=mysql:8.4
ENROLLMENT_DB_IMAGE=mysql:8.4

# Database names
STUDENT_DB_NAME=student_db
COURSE_DB_NAME=course_db
ENROLLMENT_DB_NAME=enrollment_db

# Database users
STUDENT_DB_USERNAME=student_user
COURSE_DB_USERNAME=course_user
ENROLLMENT_DB_USERNAME=enrollment_user

# Database passwords
STUDENT_DB_PASSWORD=student_password
COURSE_DB_PASSWORD=course_password
ENROLLMENT_DB_PASSWORD=enrollment_password

# Database root passwords
STUDENT_DB_ROOT_PASSWORD=root_password
COURSE_DB_ROOT_PASSWORD=root_password
ENROLLMENT_DB_ROOT_PASSWORD=root_password

# Host database ports
STUDENT_DB_PORT=3307
COURSE_DB_PORT=3308
ENROLLMENT_DB_PORT=3309

# Spring service ports
STUDENT_SERVICE_PORT=8081
COURSE_SERVICE_PORT=8082
ENROLLMENT_SERVICE_PORT=8083
API_GATEWAY_PORT=8080

# JDBC URLs for service containers
STUDENT_DB_URL=jdbc:mysql://student-db:3306/student_db
COURSE_DB_URL=jdbc:mysql://course-db:3306/course_db
ENROLLMENT_DB_URL=jdbc:mysql://enrollment-db:3306/enrollment_db

# Internal service URLs
STUDENT_SERVICE_URL=http://student-service:8081
COURSE_SERVICE_URL=http://course-service:8082
ENROLLMENT_SERVICE_URL=http://enrollment-service:8083
